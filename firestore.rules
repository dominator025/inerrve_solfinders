rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isArtisan() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artisan';
    }

    // ─── Users Collection ─────────────────────────────────────
    match /users/{userId} {
      // Users can read their own profile; admins can read any
      allow read: if isOwner(userId) || isAdmin();

      // Users can update their own profile (not role field)
      allow update: if isOwner(userId) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      // Only Cloud Functions create user docs (via auth trigger)
      allow create: if false;
      allow delete: if isAdmin();
    }

    // ─── Artisans Collection ──────────────────────────────────
    match /artisans/{artisanId} {
      // Anyone can read artisan profiles (public marketplace)
      allow read: if true;

      // Only the owning user can update their artisan profile
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;

      // Creation handled by Cloud Functions
      allow create: if false;
      allow delete: if isAdmin();
    }

    // ─── Products Collection ──────────────────────────────────
    match /products/{productId} {
      // Anyone can read products (public marketplace)
      allow read: if true;

      // Only the artisan who owns the product can update it
      allow update: if isAuthenticated() &&
        resource.data.artisanId in
          getArtisanIdsForUser(request.auth.uid);

      // Creation handled by Cloud Functions
      allow create: if false;
      allow delete: if isAdmin() || (isAuthenticated() &&
        resource.data.artisanId in
          getArtisanIdsForUser(request.auth.uid));
    }

    // ─── Orders Collection ────────────────────────────────────
    match /orders/{orderId} {
      // Buyer can read their own orders
      allow read: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid ||
         resource.data.artisanId in getArtisanIdsForUser(request.auth.uid));

      // Authenticated users can create orders
      allow create: if isAuthenticated() &&
        request.resource.data.buyerId == request.auth.uid;

      // Only status updates by artisan or admin
      allow update: if isAdmin() || (isAuthenticated() &&
        resource.data.artisanId in getArtisanIdsForUser(request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));

      allow delete: if isAdmin();
    }

    // ─── Helper: Get artisan IDs for a user ───────────────────
    // Note: Firestore rules don't support subcollection queries,
    // so product updates are validated in Cloud Functions instead.
    // This is a simplified rule for basic protection.
    function getArtisanIdsForUser(uid) {
      // Simplified: artisan ownership is validated in Cloud Functions
      // This rule provides a basic layer of protection
      return [];
    }
  }
}
